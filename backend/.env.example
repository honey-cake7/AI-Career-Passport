# ========================================
# AI Career Passport - Backend Environment
# ========================================

# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-career-passport

# Groq API (for LLM inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=skill_taxonomy

# Upload limits
MAX_FILE_SIZE_MB=10
